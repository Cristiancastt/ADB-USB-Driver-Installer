{
  "AdbInstaller": {
    "BaseUrl": "https://dl.google.com/android/repository",
    "PlatformTools": {
      "Windows": "platform-tools-latest-windows.zip",
      "Linux": "platform-tools-latest-linux.zip",
      "MacOS": "platform-tools-latest-darwin.zip"
    },
    "UsbDriver": {
      "Windows": "usb_driver_r13-windows.zip"
    },
    "DefaultInstallPaths": {
      "Windows": "%LOCALAPPDATA%\\Android\\platform-tools",
      "Linux": "~/.android/platform-tools",
      "MacOS": "~/Library/Android/platform-tools"
    },
    "SystemInstallPaths": {
      "Windows": "C:\\Android\\platform-tools",
      "Linux": "/opt/android/platform-tools",
      "MacOS": "/opt/android/platform-tools"
    }
  }
}
